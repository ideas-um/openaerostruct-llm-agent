#
# Copy this file to `.env` and fill in the values you need.
# Gemini requires one API key. Ollama does not require a key for the default
# local daemon, but you do need the Ollama app/server running and at least one
# model pulled locally.
#

# Gemini configuration
GEMINI_API_KEY="YOUR_GOOGLE_GEMINI_KEY"
# GOOGLE_API_KEY="YOUR_GOOGLE_GEMINI_KEY"

# Optional Ollama configuration
# The current code uses the default local Ollama daemon.
# Example model names you might use in the UI:
# OLLAMA_MODEL="gemini-2.0-flash"
# OLLAMA_HOST="http://127.0.0.1:11434"

# Optional execution backend for generated OpenAeroStruct scripts
# Set to "docker" to run generated scripts in the Docker sandbox,
# "host" to always run locally, or "auto" to prefer Docker when available.
OAS_EXECUTION_BACKEND="auto"
